# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Twitter / X (cookie-based via twikit) ──────────────────────────────────
# Log in once, copy cookies from browser devtools → Application → Cookies
TWITTER_AUTH_TOKEN=your-auth-token-cookie
TWITTER_CT0=your-ct0-cookie

# ─── TikTok (unofficial API) ─────────────────────────────────────────────────
# Session cookie from TikTok.com after login
TIKTOK_SESSION_ID=your-tiktok-sessionid

# ─── Instagram (Instaloader) ─────────────────────────────────────────────────
INSTAGRAM_USERNAME=your-ig-username
INSTAGRAM_PASSWORD=your-ig-password

# ─── World Cup API (wc2026api.com free tier) ─────────────────────────────────
WC_API_KEY=your-wc2026api-key
WC_API_BASE=https://api.wc2026api.com/v1

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# How often to scrape (in minutes)
SCRAPE_INTERVAL_MINUTES=30

# How many top influencers to seed on first run
TOP_INFLUENCERS_SEED=100
