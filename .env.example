# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Twitter / X (cookie-based via twikit) ──────────────────────────────────
# Log in once, copy cookies from browser devtools → Application → Cookies
TWITTER_AUTH_TOKEN=your-auth-token-cookie
TWITTER_CT0=your-ct0-cookie

# ─── TikTok (unofficial API) ─────────────────────────────────────────────────
# Session cookie from TikTok.com after login
TIKTOK_SESSION_ID=your-tiktok-sessionid

# ─── Instagram (Instaloader) ─────────────────────────────────────────────────
INSTAGRAM_USERNAME=your-ig-username
INSTAGRAM_PASSWORD=your-ig-password

# ─── World Cup API (wc2026api.com free tier) ─────────────────────────────────
WC_API_KEY=your-wc2026api-key
WC_API_BASE=https://api.wc2026api.com/v1

# ─── Discord ──────────────────────────────────────────────────────────────────
# Create a webhook: Discord Server → Edit Channel → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# ─── Polymarket autobet ───────────────────────────────────────────────────────
# Paper mode (default) needs NO credentials — it records bets vs real prices.
# Live mode requires a funded Polygon wallet + CLOB API creds from Polymarket.
POLYMARKET_LIVE_ENABLED=false
POLYMARKET_BANKROLL=1000
POLYMARKET_KELLY_MULTIPLIER=0.25
POLYMARKET_MIN_EDGE=0.05
POLYMARKET_PAPER_MIN_EDGE=0.025
POLYMARKET_PAPER_MIN_HISTORY=15
POLYMARKET_PAPER_MAX_MODEL_WEIGHT=0.65
# Price-tier learning gates (longshots need higher edge + win prob)
POLYMARKET_LONGSHOT_MIN_EDGE_PAPER=0.05
POLYMARKET_LONGSHOT_MIN_EDGE_LIVE=0.08
POLYMARKET_UNDERDOG_MIN_EDGE_PAPER=0.035
POLYMARKET_UNDERDOG_MIN_EDGE_LIVE=0.05
POLYMARKET_LONGSHOT_MIN_MODEL_PROB=0.30
POLYMARKET_UNDERDOG_MIN_MODEL_PROB=0.25
POLYMARKET_COINFLIP_MIN_MODEL_PROB=0.35
POLYMARKET_FAVORITE_MIN_MODEL_PROB=0.50
POLYMARKET_LIVE_MIN_SETTLED_BETS=50
POLYMARKET_LIVE_MIN_ROI_PCT=0.0
CLV_WEIGHT_SCALE=2.0
CONSENSUS_MIN_PICKS=3
# Paper-mode loosened gates (more autobets for learning)
POLYMARKET_PAPER_MIN_CONSENSUS_CONFIDENCE=0.42
CONSENSUS_MIN_PICKS_PAPER=2
POLYMARKET_PAPER_MIN_LIQUIDITY=100
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# How often to scrape (in minutes)
SCRAPE_INTERVAL_MINUTES=30

# How many top influencers to seed on first run
TOP_INFLUENCERS_SEED=100
