# Generate at: https://trading.kalshi.com/settings/api
KALSHI_API_KEY=your-kalshi-api-key-uuid
# Path to the RSA private key PEM downloaded alongside the API key
# Or set KALSHI_PRIVATE_KEY_B64 for GitHub Actions (base64-encoded PEM)
KALSHI_PRIVATE_KEY_PATH=./data/kalshi_private_key.pem
# Discord bot mode (Railway only). For GitHub Actions use DISCORD_WEBHOOK_URL instead.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
# Same webhook as SportsPick consensus alerts (GitHub Actions / unified channel)
DISCORD_WEBHOOK_URL=
MIN_EDGE_THRESHOLD=0.15
KELLY_FRACTION=0.25
CHECK_INTERVAL_MINUTES=30

# Polymarket US (weather)
# POLY_KEY_ID=
# POLY_SECRET_KEY=

# OpenWeatherMap (optional ensemble)
# OWM_API_KEY=

# Optional: persistent state root (logs, learning data).
# GitHub Actions uses Supabase pavlov_state table; local dev can set:
# STATE_DIRECTORY=./pavlov/_state
