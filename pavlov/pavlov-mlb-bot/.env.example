MLB_API_BASE=https://statsapi.mlb.com/api/v1
POLYMARKET_API_KEY=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
MIN_EDGE_THRESHOLD=0.12
KELLY_FRACTION=0.25
CHECK_INTERVAL_MINUTES=60

# Optional: Polymarket US trading (see README)
# POLY_KEY_ID=
# POLY_SECRET_KEY=
# Optional: persistent root for logs/ + data/ (Railway: attach ONE volume and either set
# STATE_DIRECTORY to its mount path or rely on RAILWAY_VOLUME_MOUNT_PATH — same volume for all state)
# STATE_DIRECTORY=
# MLB Polymarket auto-bet (Railway / prod)
# POLY_MLB_AUTO_BET_ENABLED=1
# POLY_MLB_PREGAME_AUTO_ENABLED=1
# Pregame auto: primary gate is model **confidence** (0–1); optional extra |edge| if POLY_MLB_AUTO_MIN_EDGE > 0
# POLY_MLB_AUTO_MIN_MODEL_CONFIDENCE=0.58
# POLY_MLB_AUTO_MIN_EDGE=0
# POLY_MLB_AUTO_MAX_KELLY_DOLLARS=3
# POLY_MLB_AUTO_MAX_CONTRACTS=2
# POLY_MLB_AUTO_MAX_BETS_PER_ET_DAY=5
# POLY_MLB_AUTO_REQUIRE_STRONG=0
# In-game auto (live lead + inning + Polymarket band; learns thresholds in data/mlb_ingame_learning.json)
# POLY_MLB_INGAME_ENABLED=1
# POLY_MLB_INGAME_POLL_MINUTES=12
# POLY_MLB_INGAME_MAX_KELLY_DOLLARS=2
# POLY_MLB_INGAME_MAX_CONTRACTS=1
# POLY_MLB_INGAME_MAX_BETS_PER_ET_DAY=5
